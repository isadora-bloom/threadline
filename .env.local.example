# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URL (used for invitation links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Threadline <noreply@yourdomain.com>

# Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=64_character_hex_string

# Rate limiting (Upstash Redis — https://upstash.com, free tier available)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# Virus scanning webhook (optional — for future integration)
SCAN_WEBHOOK_SECRET=your_webhook_secret
